{
  "info": {
    "name": "Indian Name Blog",
    "description": "Full test collection for the Indian Name Blog with Secret-Key Controlled API Access.\n\nBase URL: http://localhost:5005\n\n**Flow:**\n1. Register Admin\n2. Admin Login (saves adminToken automatically)\n3. Admin creates Writer\n4. Writer Login (saves writerToken automatically)\n5. User Register → User Login (saves userToken automatically)\n6. Test blog CRUD via single /blog endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",               "value": "http://localhost:5005",          "type": "string" },
    { "key": "adminToken",            "value": "",                               "type": "string" },
    { "key": "adminRefreshToken",     "value": "",                               "type": "string" },
    { "key": "writerToken",           "value": "",                               "type": "string" },
    { "key": "writerRefreshToken",    "value": "",                               "type": "string" },
    { "key": "userToken",             "value": "",                               "type": "string" },
    { "key": "userRefreshToken",      "value": "",                               "type": "string" },
    { "key": "adminSecretKey",        "value": "admin-super-secret-key-2024",    "type": "string" },
    { "key": "writerSecretKey",       "value": "writer-super-secret-key-2024",   "type": "string" },
    { "key": "blogId",                "value": "",                               "type": "string" },
    { "key": "categoryId",            "value": "",                               "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Admin",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/register", "host": ["{{baseUrl}}"], "path": ["admin","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adminName\": \"Aarav Sharma\",\n  \"email\": \"admin@indiannameblog.com\",\n  \"password\": \"Admin@1234\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', json.accessToken);",
                  "  pm.collectionVariables.set('adminRefreshToken', json.refreshToken);",
                  "  console.log('Admin token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/login", "host": ["{{baseUrl}}"], "path": ["admin","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@indiannameblog.com\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Refresh Admin Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/refresh-token", "host": ["{{baseUrl}}"], "path": ["admin","refresh-token"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{adminRefreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/logout", "host": ["{{baseUrl}}"], "path": ["admin","logout"] },
            "body": { "mode": "raw", "raw": "" }
          }
        },
        {
          "name": "Update Admin Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/update-password", "host": ["{{baseUrl}}"], "path": ["admin","update-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@1234\",\n  \"newPassword\": \"Admin@5678\"\n}"
            }
          }
        },
        {
          "name": "Create Writer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/create-writer", "host": ["{{baseUrl}}"], "path": ["admin","create-writer"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"writerName\": \"Ishan Gupta\",\n  \"email\": \"writer@indiannameblog.com\",\n  \"password\": \"Writer@1234\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "🔐 Admin — Blog (Single Endpoint)",
      "item": [
        {
          "name": "Get All Blogs (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog", "host": ["{{baseUrl}}"], "path": ["admin","blog"] }
          }
        },
        {
          "name": "Get Single Blog (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog/{{blogId}}", "host": ["{{baseUrl}}"], "path": ["admin","blog","{{blogId}}"] }
          }
        },
        {
          "name": "Create Blog (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('blogId', json.data._id);",
                  "  console.log('blogId saved:', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog", "host": ["{{baseUrl}}"], "path": ["admin","blog"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Explore the Beauty of Jaipur\",\n  \"content\": \"Jaipur, the Pink City, is a mesmerizing blend of heritage and modern life...\",\n  \"excerpt\": \"Short description here\",\n  \"category\": null\n}"
            }
          }
        },
        {
          "name": "Update Blog (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog/{{blogId}}", "host": ["{{baseUrl}}"], "path": ["admin","blog","{{blogId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Blog Title\",\n  \"status\": \"published\"\n}"
            }
          }
        },
        {
          "name": "Delete Blog (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog/{{blogId}}", "host": ["{{baseUrl}}"], "path": ["admin","blog","{{blogId}}"] }
          }
        },
        {
          "name": "Approve Blog",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog/approval/{{blogId}}", "host": ["{{baseUrl}}"], "path": ["admin","blog","approval","{{blogId}}"] },
            "body": { "mode": "raw", "raw": "" }
          }
        },
        {
          "name": "Reject Blog",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "x-secret-key",  "value": "{{adminSecretKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/blog/reject/{{blogId}}", "host": ["{{baseUrl}}"], "path": ["admin","blog","reject","{{blogId}}"] },
            "body": { "mode": "raw", "raw": "" }
          }
        }
      ]
    },

